OPENAI_API_KEY=cole_sua_chave_aqui
OPENAI_VISION_MODEL=gpt-5.4-mini
PORT=3000
DB_FILE=./database.db
INITIAL_ADMIN_USER=godofredo
INITIAL_ADMIN_PASSWORD=troque_esta_senha
APP_BASE_URL=https://seu-dominio.up.railway.app

# Reset de senha por e-mail
# Recomendado no Railway quando SMTP der timeout: Resend via HTTPS.
# Configure o dominio mapacc.com.br no Resend e crie uma API key.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_sua_chave_aqui
RESEND_FROM=MAPA CC <no-reply@mapacc.com.br>
RESEND_REPLY_TO=mapa_cc@outlook.com.br
EMAIL_HTTP_TIMEOUT_MS=15000

# Reset de senha por e-mail (Outlook.com)
# Host, porta e usuario ja tem defaults no codigo para mapa_cc@outlook.com.br.
# Use como fallback se a hospedagem liberar SMTP.
SMTP_HOSTS=smtp-mail.outlook.com,smtp.office365.com
SMTP_PORT=587
SMTP_USER=mapa_cc@outlook.com.br
SMTP_FROM=mapa_cc@outlook.com.br
SMTP_REQUIRE_TLS=true
SMTP_TIMEOUT_MS=60000
SMTP_PASS=senha_ou_app_password_do_outlook
